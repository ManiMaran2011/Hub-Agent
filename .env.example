# ─────────────────────────────────────────────────────────────────────────
# GHOps Bot — environment variables
# Copy this file to .env (local dev) and fill in real values.
# In production (Vercel), set these under Project Settings → Environment
# Variables instead of committing a .env file.
# ─────────────────────────────────────────────────────────────────────────

# Public URL of this deployment. Used to build OAuth callback / GitHub App
# installation callback / webhook URLs shown in the UI. No trailing slash.
NEXTAUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# Random 32+ byte secret used to sign NextAuth session JWTs.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# ── Database (Neon or Supabase Postgres, free tier, no card) ──────────────
# Pooled connection string (used at runtime).
DATABASE_URL="postgresql://user:password@host/db?sslmode=require&pgbouncer=true"
# Direct (non-pooled) connection string, required by Prisma for migrations.
DATABASE_URL_UNPOOLED="postgresql://user:password@host/db?sslmode=require"

# ── GitHub App ──────────────────────────────────────────────────────────
# Create at: https://github.com/settings/apps/new
# Permissions needed: Issues (read/write), Pull requests (read/write),
# Contents (read), Metadata (read). Subscribe to events: Issues, Pull
# request, Push, Installation, Installation repositories.
GITHUB_APP_ID=""
GITHUB_APP_CLIENT_ID=""
GITHUB_APP_CLIENT_SECRET=""
# The app's webhook secret (set the same value in the GitHub App's webhook
# config). Used to verify X-Hub-Signature-256 on every incoming webhook.
GITHUB_APP_WEBHOOK_SECRET=""
# The app's private key (.pem), downloaded once from the App settings page.
# Paste the *entire* file contents here with literal \n for newlines, e.g.:
# "-----BEGIN RSA PRIVATE KEY-----\nMIIEow...\n-----END RSA PRIVATE KEY-----\n"
GITHUB_APP_PRIVATE_KEY=""
# The app's URL slug, e.g. "ghops-bot" for github.com/apps/ghops-bot.
# Used to build the "Connect a repository" installation link.
GITHUB_APP_SLUG=""

# ── Slack ──────────────────────────────────────────────────────────────
# Create a Slack App at https://api.slack.com/apps, add the chat:write
# scope, install it to your workspace, and invite the bot to a channel.
SLACK_BOT_TOKEN=""
SLACK_CHANNEL_ID=""

# ── AI (optional — only needed for the AI triage stretch goal) ─────────
# Free key from https://aistudio.google.com/app/apikey — no card required.
# Leave blank to disable AI triage; the app degrades gracefully without it.
GEMINI_API_KEY=""

# ── Cron / internal auth ────────────────────────────────────────────────
# Shared secret so /api/cron/retry can't be triggered by anyone but Vercel
# Cron (which sends this as a bearer token — configured automatically when
# CRON_SECRET is set in a Vercel project) or your own manual curl for testing.
CRON_SECRET=""
